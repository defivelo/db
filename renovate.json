{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    "schedule:weekly"
  ],
  "baseBranchPatterns": [
    "staging"
  ],
  "ignorePaths": [
    "envdir/**",
    "ext/**",
    "scripts/**"
  ],
  "major": {
    "enabled": false
  },
  "pip-compile": {
    "enabled": true,
    "managerFilePatterns": ["/(^|/)[\\w-]*requirements/([-.\\w]+)\\.(txt|pip)$/"]
  },
  "pip_requirements": {
    "enabled": false
  },
  "pip_setup": {
    "enabled": false
  },
  "constraints": {
    "python": "==3.11"
  },
  "docker-compose": {
    "major": {
      "enabled": false
    },
    "minor": {
      "enabled": true
    }
  },
  "dockerfile": {
    "major": {
      "enabled": false
    },
    "minor": {
      "enabled": false
    }
  },
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "python",
        "postgres",
        "postgresql"
      ],
      "enabled": false
    },
    {
      "matchManagers": ["html"],
      "enabled": false
    }
  ]
}
